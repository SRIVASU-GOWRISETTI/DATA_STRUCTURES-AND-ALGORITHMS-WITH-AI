class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {

        //using index and following the idea of simple addition and  equating to target and checking every time is key here
int n =nums.size();

       vector<int> res;


       for(int i=0;i<n;i++){

        for(int j=i+1;j<n;j++){

        if(nums[i]+nums[j]==target){
            res.push_back(i);
            res.push_back(j);

            break;

        }
        }
    }

    return res;

       

    }
};
