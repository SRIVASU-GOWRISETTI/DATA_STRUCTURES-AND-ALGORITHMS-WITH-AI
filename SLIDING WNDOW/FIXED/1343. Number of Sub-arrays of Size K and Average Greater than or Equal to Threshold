class Solution {
public:
    int numOfSubarrays(vector<int>& arr, int k, int threshold) {

        int n=arr.size();
        int window_sum=0;
        int c=0;
        int result=0;
        for(int i=0;i<k;i++)
        {
             window_sum+=arr[i];
             
        }
        if(window_sum/k>=threshold)
        {
            c++;
        }

        for(int j=k;j<n;j++){
            window_sum+=arr[j];
            window_sum-=arr[j-k];
            result=window_sum/k;
            if(result>=threshold){
                c++;

            }

        }

        return c;   


        
    }
